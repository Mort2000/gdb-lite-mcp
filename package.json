{
  "name": "gdb-lite-mcp",
  "version": "0.2.1",
  "description": "A small TypeScript MCP server for driving gdb sessions.",
  "license": "MIT",
  "author": "Mort2000",
  "homepage": "https://github.com/Mort2000/gdb-lite-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mort2000/gdb-lite-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Mort2000/gdb-lite-mcp/issues"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "gdb",
    "debugger",
    "cli"
  ],
  "type": "module",
  "bin": {
    "gdb-lite-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "eval:build": "python3 eval/scenarios/build_scenarios.py",
    "lint": "eslint .",
    "test:ci": "tsx test/unit/mi-parser.test.ts && tsx test/unit/timeout.test.ts && tsx test/unit/buffer.test.ts && tsx test/unit/config.test.ts && tsx test/unit/gdb-session.test.ts && tsx test/gdb-controller.test.ts && tsx test/package-files.test.ts",
    "test": "npm run test:ci && python3 -m unittest discover -s test -p '*_test.py'",
    "start": "node dist/index.js",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^24.10.1",
    "eslint": "^9.20.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.24.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "GUIDE.md",
    "skills"
  ]
}
